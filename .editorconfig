root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{c,h,cpp,hpp,cc,cxx}]
indent_size = 4

[*.{f,f90,F,F90,fypp}]
indent_size = 2

[*.py]
indent_size = 4

[*.{cmake,txt}]
indent_size = 4

[CMakeLists.txt]
indent_size = 4

[*.{md,rst}]
trim_trailing_whitespace = false

[*.{yml,yaml,json}]
indent_size = 2

[Makefile]
indent_style = tab
