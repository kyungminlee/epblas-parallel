#! Consistency fuzz driver — real GBMV.

program fuzz_${routine}$
    use fuzz_util
    implicit none

    interface
        subroutine ${routine}$(trans, m, n, kl, ku, alpha, a, lda, x, incx, beta, y, incy)
            import :: rk
            character, intent(in) :: trans
            integer,   intent(in) :: m, n, kl, ku, lda, incx, incy
            real(rk), intent(in)    :: alpha, beta
            real(rk), intent(in)    :: a(lda, *), x(*)
            real(rk), intent(inout) :: y(*)
        end subroutine ${routine}$
        subroutine ${routine}$_migrated(trans, m, n, kl, ku, alpha, a, lda, x, incx, beta, y, incy)
            import :: rk
            character, intent(in) :: trans
            integer,   intent(in) :: m, n, kl, ku, lda, incx, incy
            real(rk), intent(in)    :: alpha, beta
            real(rk), intent(in)    :: a(lda, *), x(*)
            real(rk), intent(inout) :: y(*)
        end subroutine ${routine}$_migrated
    end interface

    integer :: seed, ncases, ic, m, n, kl, ku, lda, lenx, leny, fails
    integer :: incx, incy, lenx_alloc, leny_alloc
    character :: trans
    real(rk) :: alpha, beta, err, tol
    real(rk), allocatable :: A(:), X(:), Y0(:), Y_ov(:), Y_mig(:)
    real(8) :: u

    seed = read_seed(); ncases = read_cases()

    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_${routine}$: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        m = rand_int_log(1, 128)
        n = rand_int_log(1, 128)
        kl = rand_int_log(0, min(m - 1, 8)); if (kl < 0) kl = 0
        ku = rand_int_log(0, min(n - 1, 8)); if (ku < 0) ku = 0
        tol = max(10.0_rk, 4.0_rk * real(max(m, n), rk)) * eps
        call random_number(u); if (u < 0.5_8) then; trans = 'N'; else; trans = 'T'; end if
        call rand_alpha_beta(alpha, beta)
        if (trans == 'N') then; lenx = n; leny = m
        else;                   lenx = m; leny = n
        end if
        lda = (kl + ku + 1) + rand_pad()
        incx = rand_incx(); incy = rand_incx()
        lenx_alloc = 1 + (lenx - 1) * abs(incx)
        leny_alloc = 1 + (leny - 1) * abs(incy)
        allocate(A(lda * n), X(lenx_alloc), Y0(leny_alloc), Y_ov(leny_alloc), Y_mig(leny_alloc))
        call fill_matrix_real(A, kl + ku + 1, n, lda)
        call fill_matrix_real(X, lenx_alloc, 1, lenx_alloc)
        call fill_matrix_real(Y0, leny_alloc, 1, leny_alloc)
        Y_ov = Y0; Y_mig = Y0
        call ${routine}$(trans, m, n, kl, ku, alpha, A, lda, X, incx, beta, Y_ov, incy)
        call ${routine}$_migrated(trans, m, n, kl, ku, alpha, A, lda, X, incx, beta, Y_mig, incy)
        ! Denominator is max(ref_max, op_norm) — op_norm is the
        ! Wilkinson-style upper bound on |y_new| for GBMV (band width
        ! kl+ku+1 bounds the contracted dim); using it as a floor keeps
        ! relative error meaningful when α·A·x and β·y₀ cancel and
        ! ref_max collapses below operand scale.
        block
            integer :: i, k_eff
            real(rk) :: ref_max, diff_max, a_abs, d_abs
            real(rk) :: a_max, x_max, y0_max, op_norm
            k_eff = kl + ku + 1
            a_max  = maxval(abs(A(1 : lda * n)))
            x_max  = maxval(abs(X(1 : lenx_alloc)))
            y0_max = maxval(abs(Y0(1 : leny_alloc)))
            op_norm = abs(alpha) * real(k_eff, rk) * a_max * x_max &
                    + abs(beta)  * y0_max
            ref_max = 0.0_rk; diff_max = 0.0_rk
            do i = 1, leny_alloc
                a_abs = abs(Y_mig(i)); if (a_abs > ref_max) ref_max = a_abs
                d_abs = abs(Y_ov(i) - Y_mig(i)); if (d_abs > diff_max) diff_max = d_abs
            end do
            err = diff_max / max(ref_max, op_norm, tiny(1.0_rk))
        end block
        call err_stats_record(err)
        if (err > tol .or. err /= err) then
            fails = fails + 1
            print '(a,i0,a,a1,a,2i6,a,2i4,a,i3,a,i3,a,es12.4)', &
                'FAIL ', ic, ' T=', trans, ' mn=', m, n, ' klu=', kl, ku, &
                ' incx=', incx, ' incy=', incy, ' err=', err
        end if
        deallocate(A, X, Y0, Y_ov, Y_mig)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_${routine}$: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program fuzz_${routine}$
