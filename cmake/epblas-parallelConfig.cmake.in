@PACKAGE_INIT@

# epblas-parallel Config.cmake
#
# Library files carry the two-letter (real+complex) type prefix and no
# compiler tag (`libeyblas_parallel.a`, `libqxblas_parallel.a`,
# `libmwblas_parallel.a`) — the eplinalg naming convention (cf.
# eplinalg's `libeyblas-gfortran-15.a`, `libmultifloats.a`); the
# Targets export is likewise untagged (`epblas-parallelTargets.cmake`).
# The overlays implement the gfortran BLAS ABI but contain no
# Fortran-compiled objects, so the install is
# consumer-compiler-independent and no tag detection is needed here.

include(CMakeFindDependencyMacro)

# OpenMP is an interface dep of every composite (libgomp lands in
# the consumer's final link). Components are determined by which
# targets this configure linked against — multifloats's C++ kernels
# PUBLIC-link OpenMP::OpenMP_CXX, so its CXX component must be
# requested or the IMPORTED target referenced by the installed
# Targets file won't exist on the consumer side.
find_dependency(OpenMP COMPONENTS @EPBLAS_PARALLEL_OPENMP_COMPONENTS@)

# Additional dependencies of overlay targets that were built into this
# install. Currently: find_dependency(multifloats) when the multifloats
# target is present (mblas_parallel's INTERFACE_LINK_LIBRARIES
# references multifloats::multifloats).
@EPBLAS_PARALLEL_EXTRA_DEPENDENCIES@

include("${CMAKE_CURRENT_LIST_DIR}/epblas-parallelTargets.cmake")
