@PACKAGE_INIT@

# epblas-parallel Config.cmake
#
# Library files are tagged by Fortran compiler family + ABI version
# (e.g. `libeblas_parallel-gfortran-15.a`,
# `epblas-parallelTargets-gfortran-15.cmake`) so installs built with
# different compilers can coexist under one prefix. The detection
# block below re-derives the consumer's compiler tag at find_package()
# time and loads the matching Targets file. Same convention as
# eplinalg's `fortran_install_library` — kept inline here because the
# composite needs an explicit `find_dependency(OpenMP COMPONENTS ...)`
# that the eplinalg helper's generator does not support.

include(CMakeFindDependencyMacro)

# OpenMP is an interface dep of every composite (libgomp lands in
# the consumer's final link). Components are determined by which
# targets this configure linked against — multifloats's C++ kernels
# PUBLIC-link OpenMP::OpenMP_CXX, so its CXX component must be
# requested or the IMPORTED target referenced by the installed
# Targets file won't exist on the consumer side.
find_dependency(OpenMP COMPONENTS @EPBLAS_PARALLEL_OPENMP_COMPONENTS@)

# Additional dependencies of overlay targets that were built into this
# install. Currently: find_dependency(multifloats) when the multifloats
# target is present (mblas_parallel's INTERFACE_LINK_LIBRARIES
# references multifloats::multifloats).
@EPBLAS_PARALLEL_EXTRA_DEPENDENCIES@

# --- Derive consumer's Fortran compiler family + ABI version tag ---
# Mirrors FortranCompiler.cmake (and eplinalg's identical block).
set(_FC_consumer_family "")
if(CMAKE_Fortran_COMPILER_ID STREQUAL "GNU")
    set(_FC_consumer_family "gfortran")
elseif(CMAKE_Fortran_COMPILER_ID STREQUAL "Intel")
    set(_FC_consumer_family "intel")
elseif(CMAKE_Fortran_COMPILER_ID STREQUAL "IntelLLVM")
    set(_FC_consumer_family "intel")
elseif(CMAKE_Fortran_COMPILER_ID STREQUAL "LLVMFlang")
    set(_FC_consumer_family "flang")
elseif(CMAKE_Fortran_COMPILER_ID STREQUAL "Flang")
    set(_FC_consumer_family "flang-classic")
elseif(CMAKE_Fortran_COMPILER_ID STREQUAL "NVHPC")
    set(_FC_consumer_family "nvhpc")
elseif(CMAKE_Fortran_COMPILER_ID STREQUAL "NAG")
    set(_FC_consumer_family "nag")
elseif(CMAKE_Fortran_COMPILER_ID STREQUAL "Cray")
    set(_FC_consumer_family "cray")
else()
    set(_FC_consumer_family "${CMAKE_Fortran_COMPILER_ID}")
    string(TOLOWER "${_FC_consumer_family}" _FC_consumer_family)
endif()

if(_FC_consumer_family STREQUAL "gfortran" OR _FC_consumer_family STREQUAL "flang")
    string(REGEX MATCH "^([0-9]+)" _FC_abi_version "${CMAKE_Fortran_COMPILER_VERSION}")
elseif(_FC_consumer_family STREQUAL "intel")
    string(REGEX MATCH "^([0-9]+\\.[0-9]+)" _FC_abi_version "${CMAKE_Fortran_COMPILER_VERSION}")
else()
    set(_FC_abi_version "${CMAKE_Fortran_COMPILER_VERSION}")
endif()
set(_FC_consumer_tag "${_FC_consumer_family}-${_FC_abi_version}")

set(_FC_targets_file "${CMAKE_CURRENT_LIST_DIR}/epblas-parallelTargets-${_FC_consumer_tag}.cmake")

if(NOT EXISTS "${_FC_targets_file}")
    file(GLOB _FC_available "${CMAKE_CURRENT_LIST_DIR}/epblas-parallelTargets-*.cmake")
    set(_FC_available_names "")
    foreach(_FC_f IN LISTS _FC_available)
        get_filename_component(_FC_fname "${_FC_f}" NAME)
        list(APPEND _FC_available_names "${_FC_fname}")
    endforeach()
    list(JOIN _FC_available_names ", " _FC_available_list)
    set(${CMAKE_FIND_PACKAGE_NAME}_FOUND FALSE)
    set(${CMAKE_FIND_PACKAGE_NAME}_NOT_FOUND_MESSAGE
        "epblas-parallel: no pre-built library for tag '${_FC_consumer_tag}'. Available: [${_FC_available_list}]")
    return()
endif()

include("${_FC_targets_file}")

unset(_FC_consumer_family)
unset(_FC_abi_version)
unset(_FC_consumer_tag)
unset(_FC_targets_file)
unset(_FC_available)
unset(_FC_available_names)
unset(_FC_available_list)
