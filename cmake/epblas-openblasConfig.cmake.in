@PACKAGE_INIT@

# epblas-openblas Config.cmake
#
# Ships standalone OpenBLAS-derived reference archives
# (`epblas-openblas::{ey,qx,mw}blas`) used for A/B comparisons against the
# eplinalg migrated baseline. The archives do NOT link `eplinalg::*` at
# install time — they are raw archives, no composite — so no
# find_dependency() on per-precision eplinalg packages is needed.
#
# Library files carry the two-letter (real+complex) type prefix and no
# compiler tag (`libeyblas_openblas.a`, `libqxblas_openblas.a`,
# `libmwblas_openblas.a`) — the eplinalg naming convention; the Targets
# export is likewise untagged (`epblas-openblasTargets.cmake`). The
# archives implement the gfortran BLAS ABI but contain no
# Fortran-compiled objects, so the install is
# consumer-compiler-independent and no tag detection is needed here.

include("${CMAKE_CURRENT_LIST_DIR}/epblas-openblasTargets.cmake")
