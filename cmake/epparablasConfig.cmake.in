@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# For each target this build linked against, the corresponding
# migrator package is a hard dependency: the composite target
# `epparablas::<prefix>blas` resolves to overlay-WHOLE_ARCHIVE
# followed by `epla::<prefix>blas` from the migrator's install.
@EPPARABLAS_FIND_DEPENDENCY_BLOCK@

# OpenMP is an interface dep of every composite (libgomp lands in
# the consumer's final link).
find_dependency(OpenMP COMPONENTS C)

include("${CMAKE_CURRENT_LIST_DIR}/epparablasTargets.cmake")
