{
    "version": 6,
    "cmakeMinimumRequired": {"major": 3, "minor": 25},

    "configurePresets": [
        {
            "name": "_linux-base",
            "hidden": true,
            "description": "Linux with system gcc/g++. OpenMP via libgomp.",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },

        {
            "name": "linux",
            "displayName": "Linux (gcc/g++)",
            "description": "Builds all overlays for every eplinalg target it can find on CMAKE_PREFIX_PATH.",
            "inherits": "_linux-base"
        },

        {
            "name": "release",
            "displayName": "Release",
            "description": "Optimized build (-O3). Alias of the default linux preset.",
            "inherits": "_linux-base",
            "binaryDir": "${sourceDir}/build-release",
            "cacheVariables": {"CMAKE_BUILD_TYPE": "Release"}
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "description": "Unoptimized build with debug info (-O0 -g) for gdb.",
            "inherits": "_linux-base",
            "binaryDir": "${sourceDir}/build-debug",
            "cacheVariables": {"CMAKE_BUILD_TYPE": "Debug"}
        },
        {
            "name": "asan",
            "displayName": "ASan+UBSan",
            "description": "Debug build with AddressSanitizer + UndefinedBehaviorSanitizer (see doc/dev/debugging.md).",
            "inherits": "_linux-base",
            "binaryDir": "${sourceDir}/build-asan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
                "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined"
            }
        }
    ],

    "buildPresets": [
        {
            "name": "linux",
            "configurePreset": "linux"
        },
        {"name": "release", "configurePreset": "release"},
        {"name": "debug",   "configurePreset": "debug"},
        {"name": "asan",    "configurePreset": "asan"}
    ],

    "testPresets": [
        {
            "name": "_linux-base",
            "hidden": true,
            "configurePreset": "linux",
            "output": {"outputOnFailure": true},
            "execution": {"jobs": 8, "timeout": 300}
        },
        {
            "name": "fuzz",
            "description": "Run only fuzz/consistency tests (~15s; the correctness gate).",
            "inherits": "_linux-base",
            "filter": {"include": {"label": "fuzz"}}
        },
        {
            "name": "perf",
            "description": "Run the C perf harnesses (slow; per-binary timeout 1800s).",
            "inherits": "_linux-base",
            "execution": {"jobs": 1, "timeout": 1800},
            "filter": {"include": {"label": "perf"}}
        },
        {
            "name": "sweep",
            "description": "Run the in-process dual-link sweep dual_sweep_{e,q,m} (hours).",
            "inherits": "_linux-base",
            "execution": {"jobs": 1, "timeout": 7200},
            "filter": {"include": {"label": "sweep"}}
        },
        {
            "name": "e2e",
            "description": "Run everything: fuzz + perf + sweep.",
            "inherits": "_linux-base",
            "execution": {"jobs": 1, "timeout": 7200}
        }
    ],

    "workflowPresets": [
        {
            "name": "fuzz",
            "description": "configure -> build -> fuzz tests. The everyday correctness gate.",
            "steps": [
                {"type": "configure", "name": "linux"},
                {"type": "build",     "name": "linux"},
                {"type": "test",      "name": "fuzz"}
            ]
        },
        {
            "name": "perf",
            "description": "configure -> build -> per-routine perf harnesses.",
            "steps": [
                {"type": "configure", "name": "linux"},
                {"type": "build",     "name": "linux"},
                {"type": "test",      "name": "perf"}
            ]
        },
        {
            "name": "sweep",
            "description": "configure -> build -> in-process dual-link sweep.",
            "steps": [
                {"type": "configure", "name": "linux"},
                {"type": "build",     "name": "linux"},
                {"type": "test",      "name": "sweep"}
            ]
        },
        {
            "name": "e2e",
            "description": "configure -> build -> everything (fuzz + perf + sweep). Overnight run.",
            "steps": [
                {"type": "configure", "name": "linux"},
                {"type": "build",     "name": "linux"},
                {"type": "test",      "name": "e2e"}
            ]
        }
    ]
}
