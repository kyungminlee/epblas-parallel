# Doxygen configuration template. ./doc/build.sh substitutes
# @PROJECT_VERSION@ from the repo-root VERSION file, materializes the
# generated version.h under doc/_doxygen/include/, and runs doxygen from
# doc/. Generates XML for Breathe to pull into Sphinx:
#   (cd doc && doxygen Doxyfile)   →   doc/_doxygen/xml
# The public API surface is the installed headers under include/epblas-parallel/.

PROJECT_NAME           = "epblas-parallel"
PROJECT_NUMBER         = @PROJECT_VERSION@
OUTPUT_DIRECTORY       = _doxygen
INPUT                  = _doxygen/include
FILE_PATTERNS          = *.h *.hpp
RECURSIVE              = YES

GENERATE_HTML          = NO
GENERATE_LATEX         = NO
GENERATE_XML           = YES
XML_PROGRAMLISTING     = NO

EXTRACT_ALL            = YES
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
