# Sphinx configuration template (shared shape across eplinalg /
# epblas-parallel / multifloats). ./doc/build.sh substitutes
# @PROJECT_VERSION@ from the repo-root VERSION file and writes conf.py
# (git-ignored) next to this template, then runs sphinx-build.

import os

project = "epblas-parallel"
author = "Kyungmin Lee"
copyright = "2026, Kyungmin Lee"

version = "@PROJECT_VERSION@"
release = "@PROJECT_VERSION@"

extensions = [
    "myst_parser",
    "breathe",
    "sphinx_copybutton",
    "sphinx_design",
]

myst_enable_extensions = [
    "colon_fence",
    "deflist",
    "dollarmath",
    "fieldlist",
    "substitution",
    "tasklist",
]
myst_heading_anchors = 3

# Breathe points at the Doxygen XML output; ./doc/build.sh runs doxygen
# with OUTPUT_DIRECTORY = doc/_doxygen (see Doxyfile.in).
breathe_projects = {
    "epblas-parallel": os.path.join(os.path.dirname(__file__), "_doxygen", "xml")
}
breathe_default_project = "epblas-parallel"

source_suffix = {".md": "markdown", ".rst": "restructuredtext"}
root_doc = "index"
exclude_patterns = [
    "_build",
    "_doxygen",
    ".venv",
    "*.in",
    "requirements.txt",
    "README.md",
]

html_theme = "furo"
html_title = "epblas-parallel"
html_static_path = ["_static"]
templates_path = ["_templates"]
