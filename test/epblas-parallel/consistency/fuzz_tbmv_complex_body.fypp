#! Consistency fuzz driver — complex TBMV.

program fuzz_${routine}$
    use fuzz_util
    implicit none

    interface
        subroutine ${routine}$(uplo, trans, diag, n, k, a, lda, x, incx)
            import :: rk
            character, intent(in) :: uplo, trans, diag
            integer,   intent(in) :: n, k, lda, incx
            complex(rk), intent(in)    :: a(lda, *)
            complex(rk), intent(inout) :: x(*)
        end subroutine ${routine}$
        subroutine ${routine}$_migrated(uplo, trans, diag, n, k, a, lda, x, incx)
            import :: rk
            character, intent(in) :: uplo, trans, diag
            integer,   intent(in) :: n, k, lda, incx
            complex(rk), intent(in)    :: a(lda, *)
            complex(rk), intent(inout) :: x(*)
        end subroutine ${routine}$_migrated
    end interface

    integer :: seed, ncases, ic, n, k, lda, fails, incx, lenx
    character :: uplo, trans, diag
    real(rk) :: err, tol
    complex(rk), allocatable :: A(:), X0(:), X_ov(:), X_mig(:)
    real(8) :: u

    seed = read_seed(); ncases = read_cases()

    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_${routine}$: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        ! Salt (audit F1/F2): XTBMV_OMP_MIN = 128 equals the cap (YTBMV
        ! gates at 64), so the plain draw reaches the threaded regime
        ! only at exactly n = 128 — salt every 8th case past it.
        n = rand_size_salted(ic, 1, 128, 128, 192)
        k = rand_int_log(0, min(n - 1, 8)); if (k < 0) k = 0
        tol = max(10.0_rk, 4.0_rk * real(n, rk)) * eps
        call random_number(u); if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        call random_number(u)
        if (u < 1.0_8 / 3.0_8) then; trans = 'N'
        else if (u < 2.0_8 / 3.0_8) then; trans = 'T'
        else; trans = 'C'
        end if
        call random_number(u); if (u < 0.5_8) then; diag = 'N'; else; diag = 'U'; end if
        lda = (k + 1) + rand_pad()
        incx = rand_incx(); lenx = 1 + (n - 1) * abs(incx)
        allocate(A(lda * n), X0(lenx), X_ov(lenx), X_mig(lenx))
        call fill_matrix_complex(A, k + 1, n, lda)
        call fill_matrix_complex(X0, lenx, 1, lenx)
        X_ov = X0; X_mig = X0
        call ${routine}$(uplo, trans, diag, n, k, A, lda, X_ov, incx)
        call ${routine}$_migrated(uplo, trans, diag, n, k, A, lda, X_mig, incx)
        ! Denominator is max(ref_max, op_norm) — op_norm is the
        ! Wilkinson-style upper bound on |x_new| for TBMV (A is its
        ! own scale factor); using it as a floor keeps relative error
        ! meaningful when A·x cancels and ref_max collapses below
        ! operand scale.
        block
            integer :: i
            real(rk) :: ref_max, diff_max, a_abs, d_abs
            real(rk) :: a_max, x0_max, op_norm
            a_max  = max_abs_complex(A(1 : lda * n))
            x0_max = max_abs_complex(X0(1 : lenx))
            op_norm = a_max * x0_max * real(n, rk)
            ref_max = 0.0_rk; diff_max = 0.0_rk
            do i = 1, lenx
                a_abs = abs(X_mig(i)); if (a_abs > ref_max) ref_max = a_abs
                d_abs = abs(X_ov(i) - X_mig(i)); if (d_abs > diff_max) diff_max = d_abs
            end do
            err = diff_max / max(ref_max, op_norm, tiny(1.0_rk))
        end block
        call err_stats_record(err)
        if (err > tol .or. err /= err) then
            fails = fails + 1
            print '(a,i0,a,3a1,a,i6,a,i4,a,i3,a,es12.4)', &
                'FAIL ', ic, ' UTD=', uplo, trans, diag, ' n=', n, ' k=', k, ' incx=', incx, ' err=', err
        end if
        deallocate(A, X0, X_ov, X_mig)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_${routine}$: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program fuzz_${routine}$
