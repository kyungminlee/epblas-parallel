#! Consistency fuzz driver — complex HBMV.

program fuzz_${routine}$
    use fuzz_util
    implicit none

    interface
        subroutine ${routine}$(uplo, n, k, alpha, a, lda, x, incx, beta, y, incy)
            import :: rk
            character, intent(in) :: uplo
            integer,   intent(in) :: n, k, lda, incx, incy
            complex(rk), intent(in)    :: alpha, beta
            complex(rk), intent(in)    :: a(lda, *), x(*)
            complex(rk), intent(inout) :: y(*)
        end subroutine ${routine}$
        subroutine ${routine}$_migrated(uplo, n, k, alpha, a, lda, x, incx, beta, y, incy)
            import :: rk
            character, intent(in) :: uplo
            integer,   intent(in) :: n, k, lda, incx, incy
            complex(rk), intent(in)    :: alpha, beta
            complex(rk), intent(in)    :: a(lda, *), x(*)
            complex(rk), intent(inout) :: y(*)
        end subroutine ${routine}$_migrated
    end interface

    integer :: seed, ncases, ic, n, k, lda, fails, incx, incy, lenx, leny
    character :: uplo
    complex(rk) :: alpha, beta
    real(rk) :: err, tol
    complex(rk), allocatable :: A(:), X(:), Y0(:), Y_ov(:), Y_mig(:)
    real(8) :: u

    seed = read_seed(); ncases = read_cases()

    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_${routine}$: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 128)
        k = rand_int_log(0, min(n - 1, 8)); if (k < 0) k = 0
        tol = max(10.0_rk, 4.0_rk * real(n, rk)) * eps
        call random_number(u); if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        call rand_alpha_beta_complex(alpha, beta)
        lda = (k + 1) + rand_pad()
        incx = rand_incx(); incy = rand_incx()
        lenx = 1 + (n - 1) * abs(incx)
        leny = 1 + (n - 1) * abs(incy)
        allocate(A(lda * n), X(lenx), Y0(leny), Y_ov(leny), Y_mig(leny))
        call fill_matrix_complex(A, k + 1, n, lda)
        call fill_matrix_complex(X, lenx, 1, lenx)
        call fill_matrix_complex(Y0, leny, 1, leny)
        Y_ov = Y0; Y_mig = Y0
        call ${routine}$(uplo, n, k, alpha, A, lda, X, incx, beta, Y_ov, incy)
        call ${routine}$_migrated(uplo, n, k, alpha, A, lda, X, incx, beta, Y_mig, incy)
        ! Denominator is max(ref_max, op_norm) — op_norm is the
        ! Wilkinson-style upper bound on |y_new| for HBMV; using it as
        ! a floor keeps relative error meaningful when α·A·x and β·y₀
        ! cancel and ref_max collapses below operand scale.
        block
            integer :: i
            real(rk) :: ref_max, diff_max, a_abs, d_abs
            real(rk) :: a_max, x_max, y0_max, op_norm
            a_max  = max_abs_complex(A(1 : lda * n))
            x_max  = max_abs_complex(X(1 : lenx))
            y0_max = max_abs_complex(Y0(1 : leny))
            op_norm = abs(alpha) * real(n, rk) * a_max * x_max &
                    + abs(beta)  * y0_max
            ref_max = 0.0_rk; diff_max = 0.0_rk
            do i = 1, leny
                a_abs = abs(Y_mig(i)); if (a_abs > ref_max) ref_max = a_abs
                d_abs = abs(Y_ov(i) - Y_mig(i)); if (d_abs > diff_max) diff_max = d_abs
            end do
            err = diff_max / max(ref_max, op_norm, tiny(1.0_rk))
        end block
        call err_stats_record(err)
        if (err > tol .or. err /= err) then
            fails = fails + 1
            print '(a,i0,a,a1,a,i6,a,i4,a,i3,a,i3,a,es12.4)', &
                'FAIL ', ic, ' U=', uplo, ' n=', n, ' k=', k, &
                ' incx=', incx, ' incy=', incy, ' err=', err
        end if
        deallocate(A, X, Y0, Y_ov, Y_mig)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_${routine}$: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program fuzz_${routine}$
