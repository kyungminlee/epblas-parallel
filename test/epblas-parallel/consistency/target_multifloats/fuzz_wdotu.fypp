! fuzz_wdotu — multifloats DOT.
program fuzz_wdotu
    use multifloats
    use fuzz_util
    implicit none
    interface
        function wdotu(n, x, incx, y, incy) result(d)
            import :: real64x2, cmplx64x2
            integer, intent(in) :: n, incx, incy
            type(cmplx64x2), intent(in) :: x(*), y(*)
            type(cmplx64x2) :: d
        end function
        function wdotu_migrated(n, x, incx, y, incy) result(d)
            import :: real64x2, cmplx64x2
            integer, intent(in) :: n, incx, incy
            type(cmplx64x2), intent(in) :: x(*), y(*)
            type(cmplx64x2) :: d
        end function
    end interface
    integer :: seed, ncases, ic, n, incx, incy, lenx, leny, fails
    type(cmplx64x2) :: d_ov, d_mig
    type(real64x2) :: err, tol
    type(cmplx64x2), allocatable :: X(:), Y(:)
    seed = read_seed(); ncases = read_cases(); call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_wdotu: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        ! Salt (audit F1): WDOTU_OMP_MIN = 8192 (serial when n <= gate)
        ! sits above the 4096 cap — every 8th
        ! case draws from the threaded regime.
        n = rand_size_salted(ic, 1, 4096, 8193, 16384); incx = rand_incx(); incy = rand_incx()
        lenx = 1 + (n - 1) * abs(incx); leny = 1 + (n - 1) * abs(incy)
        allocate(X(lenx), Y(leny))
        call fill_matrix_complex(X, lenx, 1, lenx); call fill_matrix_complex(Y, leny, 1, leny)
        d_ov  = wdotu(n, X, incx, Y, incy)
        d_mig = wdotu_migrated(n, X, incx, Y, incy)
        block
            type(real64x2) :: am, dm, tv, op_norm
            am = abs(d_mig); dm = abs(d_ov - d_mig); tv = real64x2(tiny(1.0_8))
            op_norm = real64x2(real(n, 8)) * max_abs_complex(X) * max_abs_complex(Y)
            if (op_norm > am) am = op_norm
            if (am < tv) then; err = dm; else; err = dm / am; end if
        end block
        tol = max(real64x2(10.0_8), real64x2(4.0_8 * real(n, 8))) * eps
        call err_stats_record(err%limbs(1))
        if (err > tol) then; fails = fails + 1; print '(a,i0,a,3i6)', 'FAIL ', ic, ' n,incx,incy=', n, incx, incy; end if
        deallocate(X, Y)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_wdotu: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program
