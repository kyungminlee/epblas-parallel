#! Consistency fuzz driver — complex GEMV, parameterized by routine.

program fuzz_${routine}$
    use fuzz_util
    implicit none

    interface
        subroutine ${routine}$(trans, m, n, alpha, a, lda, x, incx, beta, y, incy)
            import :: rk
            character, intent(in) :: trans
            integer,   intent(in) :: m, n, lda, incx, incy
            complex(rk), intent(in)    :: alpha, beta
            complex(rk), intent(in)    :: a(lda, *), x(*)
            complex(rk), intent(inout) :: y(*)
        end subroutine ${routine}$
        subroutine ${routine}$_migrated(trans, m, n, alpha, a, lda, x, incx, beta, y, incy)
            import :: rk
            character, intent(in) :: trans
            integer,   intent(in) :: m, n, lda, incx, incy
            complex(rk), intent(in)    :: alpha, beta
            complex(rk), intent(in)    :: a(lda, *), x(*)
            complex(rk), intent(inout) :: y(*)
        end subroutine ${routine}$_migrated
    end interface

    integer :: seed, ncases, ic
    integer :: m, n, lda, lenx, leny, incx, incy, lenx_alloc, leny_alloc
    integer :: fails
    character :: trans
    complex(rk) :: alpha, beta
    real(rk) :: err, tol
    complex(rk), allocatable :: A(:), X(:), Y0(:), Y_ov(:), Y_mig(:)
    real(8) :: u

    seed = read_seed()
    ncases = read_cases()
    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_${routine}$: seed=', seed, '  cases=', ncases
    call seed_rng(seed)

    fails = 0
    do ic = 1, ncases
        m = rand_int_log(1, 192)
        n = rand_int_log(1, 192)
        tol = max(10.0_rk, 4.0_rk * real(max(m, n), rk)) * eps
        call random_number(u)
        if (u < 1.0_8 / 3.0_8) then; trans = 'N'
        else if (u < 2.0_8 / 3.0_8) then; trans = 'T'
        else; trans = 'C'
        end if
        call rand_alpha_beta_complex(alpha, beta)

        if (trans == 'N') then; lenx = n; leny = m
        else;                   lenx = m; leny = n
        end if
        lda = m + rand_pad()
        if (lda < 1) lda = 1
        incx = rand_incx(); incy = rand_incx()
        lenx_alloc = 1 + (lenx - 1) * abs(incx)
        leny_alloc = 1 + (leny - 1) * abs(incy)

        allocate(A(lda * n))
        allocate(X(lenx_alloc))
        allocate(Y0(leny_alloc))
        allocate(Y_ov(leny_alloc))
        allocate(Y_mig(leny_alloc))

        call fill_matrix_complex(A,  m,          n, lda)
        call fill_matrix_complex(X,  lenx_alloc, 1, lenx_alloc)
        call fill_matrix_complex(Y0, leny_alloc, 1, leny_alloc)
        Y_ov  = Y0
        Y_mig = Y0

        call ${routine}$(trans, m, n, alpha, A, lda, X, incx, beta, Y_ov,  incy)
        call ${routine}$_migrated(trans, m, n, alpha, A, lda, X, incx, beta, Y_mig, incy)

        ! Denominator is max(ref_max, op_norm) — op_norm is the
        ! Wilkinson-style upper bound on |y_new| for GEMV; using it as
        ! a floor keeps relative error meaningful when α·A·x and β·y₀
        ! cancel and ref_max collapses below operand scale.
        block
            integer :: i, k_eff
            real(rk) :: ref_max, diff_max, a_abs, d_abs
            real(rk) :: a_max, x_max, y0_max, op_norm
            complex(rk) :: dz
            if (trans == 'N') then; k_eff = n; else; k_eff = m; end if
            a_max  = max_abs_complex(A(1 : lda * n))
            x_max  = max_abs_complex(X(1 : lenx_alloc))
            y0_max = max_abs_complex(Y0(1 : leny_alloc))
            op_norm = abs(alpha) * real(k_eff, rk) * a_max * x_max &
                    + abs(beta)  * y0_max
            ref_max = 0.0_rk; diff_max = 0.0_rk
            do i = 1, leny_alloc
                a_abs = abs(Y_mig(i))
                if (a_abs > ref_max) ref_max = a_abs
                dz = Y_ov(i) - Y_mig(i)
                d_abs = abs(dz)
                if (d_abs > diff_max) diff_max = d_abs
            end do
            err = diff_max / max(ref_max, op_norm, tiny(1.0_rk))
        end block

        call err_stats_record(err)

        if (err > tol .or. err /= err) then
            fails = fails + 1
            print '(a,i0,a,a1,a,2i6,a,i6,a,i3,a,i3,a,es12.4,a,es12.4)', &
                'FAIL case ', ic, '  T=', trans, &
                '  mn=', m, n, '  lda=', lda, &
                '  incx=', incx, '  incy=', incy, &
                '  err=', err, '  tol=', tol
        end if

        deallocate(A, X, Y0, Y_ov, Y_mig)
    end do

    print '(a,i0,a,i0,a,i0)', &
        'fuzz_${routine}$: ', ncases - fails, '/', ncases, &
        ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program fuzz_${routine}$
