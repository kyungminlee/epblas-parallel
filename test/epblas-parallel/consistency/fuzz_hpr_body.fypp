#! Consistency fuzz driver — complex HPR (alpha is real).

program fuzz_${routine}$
    use fuzz_util
    implicit none

    interface
        subroutine ${routine}$(uplo, n, alpha, x, incx, ap)
            import :: rk
            character, intent(in) :: uplo
            integer,   intent(in) :: n, incx
            real(rk), intent(in)    :: alpha
            complex(rk), intent(in)    :: x(*)
            complex(rk), intent(inout) :: ap(*)
        end subroutine ${routine}$
        subroutine ${routine}$_migrated(uplo, n, alpha, x, incx, ap)
            import :: rk
            character, intent(in) :: uplo
            integer,   intent(in) :: n, incx
            real(rk), intent(in)    :: alpha
            complex(rk), intent(in)    :: x(*)
            complex(rk), intent(inout) :: ap(*)
        end subroutine ${routine}$_migrated
    end interface

    integer :: seed, ncases, ic, n, np, fails, incx, lenx
    character :: uplo
    real(rk) :: alpha, dummy_beta, err, tol
    complex(rk), allocatable :: AP0(:), AP_ov(:), AP_mig(:), X(:)
    real(8) :: u

    seed = read_seed(); ncases = read_cases()

    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_${routine}$: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 128)
        tol = max(10.0_rk, 4.0_rk * real(n, rk)) * eps
        call random_number(u); if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        call rand_alpha_beta(alpha, dummy_beta)
        np = (n * (n + 1)) / 2
        incx = rand_incx()
        lenx = 1 + (n - 1) * abs(incx)
        allocate(AP0(np), AP_ov(np), AP_mig(np), X(lenx))
        call fill_matrix_complex(AP0, np, 1, np)
        call fill_matrix_complex(X, lenx, 1, lenx)
        AP_ov = AP0; AP_mig = AP0
        call ${routine}$(uplo, n, alpha, X, incx, AP_ov)
        call ${routine}$_migrated(uplo, n, alpha, X, incx, AP_mig)
        ! Denominator is max(ref_max, op_norm) — op_norm is the
        ! Wilkinson-style upper bound on |A_new| for HPR; using it as
        ! a floor keeps relative error meaningful when α·x·xᴴ and A₀
        ! cancel and ref_max collapses below operand scale.
        block
            integer :: i
            real(rk) :: ref_max, diff_max, a_abs, d_abs
            real(rk) :: a0_max, x_max, op_norm
            a0_max = max_abs_complex(AP0(1 : np))
            x_max  = max_abs_complex(X(1 : lenx))
            op_norm = abs(alpha) * x_max * x_max + a0_max
            ref_max = 0.0_rk; diff_max = 0.0_rk
            do i = 1, np
                a_abs = abs(AP_mig(i)); if (a_abs > ref_max) ref_max = a_abs
                d_abs = abs(AP_ov(i) - AP_mig(i)); if (d_abs > diff_max) diff_max = d_abs
            end do
            err = diff_max / max(ref_max, op_norm, tiny(1.0_rk))
        end block
        call err_stats_record(err)
        if (err > tol .or. err /= err) then
            fails = fails + 1
            print '(a,i0,a,a1,a,i6,a,i3,a,es12.4)', &
                'FAIL ', ic, ' U=', uplo, ' n=', n, ' incx=', incx, ' err=', err
        end if
        deallocate(AP0, AP_ov, AP_mig, X)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_${routine}$: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program fuzz_${routine}$
